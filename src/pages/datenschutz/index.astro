---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Datenschutz - Ferienwohnungsverein Jungfrau" langAlt="/en/privacy/">
  <!-- Hero -->
  <section class="section page-hero hero--intro">
    <div class="container">
      <h1>Datenschutz</h1>
      <p>Der Schutz Ihrer persönlichen Daten ist uns wichtig – wir behandeln sie vertraulich und gemäss dieser Datenschutzerklärung.</p>
    </div>
  </section>

  <!-- Datenschutzerklärung (privacybee.io) -->
  <section class="section section--white">
    <div class="container">
      <iframe
        src="https://app.privacybee.io/v/cma57eytp00bv7xndoe78al9p?lang=de&type=dsg"
        title="Datenschutzerklärung"
        loading="lazy"
        style="width: 100%; height: 1000px; border: 0"
      ></iframe>
    </div>
  </section>
</Layout>
