---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
import kontakt from '../../data/kontakt.json';
import { Image } from 'astro:assets';
import sujet7 from '../../assets/images/ferienwohnungsverein-jungfrau-sujet-7.jpg';
---

<Layout
  title="Für Vermietende - Mitgliedschaft - Ferienwohnungsverein Jungfrau"
  description="Fachaustausch, gemeinsame Interessenvertretung und Bestrebungen für ein Qualitätslabel: Werden Sie Mitglied im Ferienwohnungsverein Jungfrau."
  langAlt="/en/membership/"
>
  <!-- Hero -->
  <section class="section page-hero hero--intro">
    <div class="container">
      <h1>Werden Sie Mitglied</h1>
      <p>Der Ferienwohnungsverein Jungfrau ist in erster Linie eine Gemeinschaft von Ferienwohnungsbetreiber:innen – der Austausch unter uns war der ursprüngliche und bleibt der wichtigste Zweck dieses Vereins.</p>
    </div>
  </section>

  <!-- Warum Mitglied werden -->
  <section class="section section--white">
    <div class="container grid-3 text-center">
      <div>
        <Icon name="user" size={64} class="role-icon" />
        <h2>Fachaustausch</h2>
        <p>Interner Austausch unter Betreiber:innen – im persönlichen Gespräch wie auch an Treffen: Gästebetreuung, Reinigung, rechtliche Fragen rund um die Kurzzeitvermietung – aus erster Hand statt aus der Theorie.</p>
      </div>
      <div>
        <Icon name="puzzle-piece" size={64} class="role-icon" />
        <h2>Gemeinsame Vertretung</h2>
        <p>Gegenüber Gemeinden und Behörden sprechen wir mit einer Stimme – als organisierter Ansprechpartner statt als Einzelperson.</p>
      </div>
      <div>
        <Icon name="check-square" size={64} class="role-icon" />
        <h2>Qualitätslabel</h2>
        <p>Es sind Bestrebungen im Gang, ein Qualitätslabel für seriöse Ferienwohnungsbetreiber:innen aufzubauen – verschiedene Ideen werden aktuell geprüft. Als Mitglied sind Sie von Anfang an dabei.</p>
      </div>
    </div>
  </section>

  <!-- Fachaustausch & Vereinsleben -->
  <section class="section section--subtle">
    <div class="container grid-2">
      <div>
        <h2>Fachaustausch &amp; Vereinsleben</h2>
        <p>Wir treffen uns regelmässig zum Erfahrungsaustausch und helfen einander mit Tipps rund um die Gästebetreuung.</p>
        <p>Mitglieder erhalten laufend Updates zur rechtlichen Entwicklung rund um Kurzzeitvermietung und Zweitwohnungen in den Bödeli-Gemeinden – direkt von unserer Koordinationsstelle für Rechtsangelegenheiten. Die Fakten- und Studienbasis dahinter halten wir im <a href="/quellen/">Quellenverzeichnis</a> transparent.</p>
        <p>Gegenüber Behörden können wir als Gruppe Ansprechpartner sein zum Thema Vermieten von Ferienwohnungen.</p>
        <a href="/ueber-uns/" class="btn btn-accent">Wer wir sind</a>
      </div>
      <Image src={sujet7} alt="" width={1024} height={959} />
    </div>
  </section>

  <!-- Anmeldung -->
  <section class="section section--white" id="anmeldung">
    <div class="container anmeldung">
      <h2 class="text-center">Interesse anmelden</h2>
      <p class="text-center">Melden Sie unverbindlich Ihr Interesse an. Sie erhalten zuerst eine Bestätigungs-E-Mail – erst nach einem Klick auf den Link darin geht Ihre Anmeldung bei uns ein. Danach melden wir uns persönlich bei Ihnen. Alternativ erreichen Sie uns telefonisch unter <a href={`tel:${kontakt.vereinsTelefonLink}`}>{kontakt.vereinsTelefon}</a>.</p>

      <!-- Danke-Meldung (wird nach Absenden eingeblendet) -->
      <div id="form-success" class="form-success" style="display:none">
        <h3>Fast geschafft.</h3>
        <p>Prüfen Sie Ihr Postfach – wir haben Ihnen einen Bestätigungslink per E-Mail geschickt. Erst nach dem Klick auf diesen Link erhalten wir Ihre Interessensanmeldung.</p>
      </div>

      <!-- Formular -->
      <div class="form-wrap" id="form-wrap">
        <form id="anmeldung-form" class="anmeldung-form" method="POST">

          <!-- Honeypot: für Menschen unsichtbar, Bots füllen es blind aus -->
          <div class="hp-field" aria-hidden="true">
            <label for="website">Website</label>
            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
          </div>

          <input type="hidden" name="locale" value="de" />

          <div class="form-group">
            <label for="name">Name Vorname *</label>
            <input type="text" id="name" name="name" required placeholder="Vorname Nachname" />
          </div>

          <div class="form-group">
            <label for="email">E-Mail *</label>
            <input type="email" id="email" name="email" required placeholder="ihre@email.ch" />
          </div>

          <div class="form-group">
            <label for="telefon">Telefonnummer <span class="optional">(optional)</span></label>
            <input type="tel" id="telefon" name="telefon" placeholder="079 000 00 00" />
          </div>

          <div class="form-group">
            <label for="betten">Anzahl Gästebetten *</label>
            <input type="number" id="betten" name="betten" min="1" step="1" required placeholder="z.B. 4" />
          </div>

          <div class="form-check">
            <input type="checkbox" id="datenschutz" name="datenschutz" required />
            <label for="datenschutz">
              Ich habe die <a href="/datenschutz/">Datenschutzerklärung</a> gelesen und bin mit der Verarbeitung meiner Daten einverstanden. *
            </label>
          </div>

          <p id="form-error" class="form-error" style="display:none"></p>

          <button type="submit" id="submit-btn" class="btn btn-accent center-btn">Interesse anmelden</button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style>
  .grid-3 p {
    margin-inline: auto;
  }

  .grid-2 h2 { margin-bottom: var(--space-2); }
  .grid-2 p { margin-bottom: var(--space-2); }
  .grid-2 .btn { margin-top: var(--space-2); }

  .anmeldung {
    max-width: 640px;
    text-align: center;
  }

  .anmeldung p {
    margin-block: var(--space-2) var(--space-3);
  }

  .anmeldung a {
    font-weight: 600;
  }

  .form-wrap {
    text-align: left;
    margin-top: var(--space-3);
  }

  .anmeldung-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  /* Honeypot: visuell verborgen, aber im DOM für Bots auslesbar */
  .hp-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-group label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  .form-group input {
    padding: 0.75rem 1rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-text);
    background: var(--color-white);
    transition: border-color 0.2s;
    width: 100%;
  }

  .form-group input:focus-visible {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(0, 77, 122, 0.2);
  }

  .optional {
    font-weight: 400;
    color: var(--color-text);
    opacity: 0.7;
  }

  .form-check {
    display: flex;
    gap: var(--space-2);
    align-items: flex-start;
  }

  .form-check input[type='checkbox'] {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    margin-top: 2px;
    accent-color: var(--color-primary);
    cursor: pointer;
  }

  .form-check label {
    font-size: var(--text-sm);
    color: var(--color-text);
    cursor: pointer;
  }

  .form-error {
    font-size: var(--text-sm);
    color: #dc2626;
    padding: var(--space-2) var(--space-3);
    background: #fff5f5;
    border: 1px solid #fecaca;
    border-radius: var(--radius-sm);
  }

  .form-success {
    padding: var(--space-4);
    background: var(--color-bg-subtle);
    border-radius: var(--radius-md);
    margin-top: var(--space-3);
  }

  .form-success h3 {
    margin-bottom: var(--space-1);
  }
</style>

<script>
  const form = document.getElementById('anmeldung-form') as HTMLFormElement | null;
  const formWrap = document.getElementById('form-wrap') as HTMLDivElement | null;
  const formSuccess = document.getElementById('form-success') as HTMLDivElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const formError = document.getElementById('form-error') as HTMLParagraphElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!formError || !submitBtn || !formWrap || !formSuccess) return;
    formError.style.display = 'none';

    const formData = new FormData(form);
    const originalText = submitBtn.textContent;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Wird gesendet…';

    try {
      const response = await fetch('/php/mitgliedschaft-anmeldung.php', {
        method: 'POST',
        body: formData,
      });

      const data = await response.json();

      if (response.ok && data.success) {
        formWrap.style.display = 'none';
        formSuccess.style.display = 'block';
        formSuccess.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } else {
        formError.textContent = data.message || 'Bitte versuchen Sie es erneut.';
        formError.style.display = 'block';
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      }
    } catch {
      formError.textContent = 'Verbindungsfehler. Bitte versuchen Sie es erneut.';
      formError.style.display = 'block';
      submitBtn.textContent = originalText;
      submitBtn.disabled = false;
    }
  });
</script>
