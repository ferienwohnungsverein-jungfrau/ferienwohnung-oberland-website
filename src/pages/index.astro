---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { Image, getImage } from 'astro:assets';
import sujet1 from '../assets/images/ferienwohnungsverein-jungfrau-sujet-1.jpg';
import sujet2 from '../assets/images/ferienwohnungsverein-jungfrau-sujet-2.jpg';
import sujet7 from '../assets/images/ferienwohnungsverein-jungfrau-sujet-7.jpg';

const heroBg = await getImage({ src: sujet2, width: 1600, height: 640, format: 'webp' });
---

<Layout
  title="Ferienwohnungsverein Jungfrau - Berner Oberland"
  langAlt="/en/"
>
  <!-- Hero -->
  <section class="section hero--statement" style={`background-image: url(${heroBg.src})`}>
    <div class="container">
      <h1>Ferienwohnungsverein Jungfrau</h1>
      <p class="hero__subline">Ein Zusammenschluss von Ferienwohnungs-Gastgeber:innen im Berner Oberland. Wir pflegen den Austausch untereinander – und bringen uns konstruktiv in die Debatte um faire Regeln zur Kurzzeitvermietung ein.</p>
    </div>
  </section>

  <!-- Zwei-Wege-Hub -->
  <section class="section section--white">
    <div class="container grid-2 paths">
      <a href="/mitgliedschaft/" class="path-card">
        <Icon name="hotel" size={56} class="role-icon" />
        <h2>Ich vermiete</h2>
        <p>Fachaustausch, Erfahrungswissen und Bestrebungen für ein Qualitätslabel – werden Sie Teil einer aktiven Gemeinschaft von Ferienwohnungsbetreibenden.</p>
        <span class="btn btn-accent">Zur Mitgliedschaft</span>
      </a>
      <a href="/unser-vorschlag/" class="path-card">
        <Icon name="puzzle-piece" size={56} class="role-icon" />
        <h2>Ich interessiere mich für die Airbnb-Debatte</h2>
        <p>Gemeinderät:in, Journalist:in oder einfach an der Regulierungsdebatte interessiert? Wir erkennen das Wohnraumproblem an – und zeigen einen Weg, der funktioniert.</p>
        <span class="btn btn-accent">Unser Vorschlag</span>
      </a>
    </div>
  </section>

  <!-- Warum wir vermieten -->
  <section class="section section--subtle">
    <div class="container grid-2">
      <Image src={sujet1} alt="" width={1024} height={768} />
      <div>
        <h2>Warum wir vermieten</h2>
        <p>Die Gründe sind vielfältig: Einige von uns bieten Ferienwohnungen im eigenen Haus an. Andere vermieten einzelne Wohnungen. Allen gemeinsam ist: Wir tun dies mit Engagement – und mit Verantwortung gegenüber unseren Gästen und unserer Region.</p>
        <a href="/ueber-uns/" class="btn btn-accent">Mehr über uns</a>
      </div>
    </div>
  </section>

  <!-- Position / Persona B: hält den Debatten-Pfad auch beim Scrollen präsent -->
  <section class="section section--white">
    <div class="container">
      <div class="position-band">
        <div>
          <p class="eyebrow">Unsere Position</p>
          <h2>Mitten in der Debatte um faire Regeln</h2>
          <p>In fünf Bödeli-Gemeinden wird über die Zukunft der Kurzzeitvermietung entschieden. Wir anerkennen den Wohnraumdruck – und zeigen mit dem bewährten Wilderswil-Modell, dass Wohnraumschutz und lebendiger Tourismus zusammengehen.</p>
          <div class="position-actions">
            <a href="/unser-vorschlag/" class="btn btn-accent">Unser Vorschlag</a>
            <a href="/fuer-gemeinden-medien/" class="text-link-strong">Für Gemeinden &amp; Medien →</a>
          </div>
          <p class="trust-note"><Icon name="check-square" size={18} /><span>Faktenbasiert und transparent: Unsere Aussagen stützen sich auf Studien und amtliche Daten. <a href="/quellen/">Zum Quellenverzeichnis →</a></span></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Mitglieder-Stimme -->
  <section class="section section--subtle">
    <div class="container">
      <figure class="testimonial">
        <blockquote>
          „Seit über einem Jahr bin ich Mitglied im Ferienwohnungsverein Jungfrau. Mich bereichern die Kontakte sehr. Es freut mich, dass ich als Mitglied die Wahrnehmung der Parahotellerie aktiv mitgestalten kann."
        </blockquote>
        <figcaption>Stefan Sterchi · <a href="https://surfershome.ch" target="_blank" rel="noopener">surfershome.ch</a></figcaption>
      </figure>
    </div>
  </section>

  <!-- Werde Mitglied Teaser -->
  <section class="section page-hero">
    <div class="container grid-2">
      <div>
        <h2>Werden Sie Mitglied</h2>
        <p>Fachaustausch mit anderen Betreiber:innen, gemeinsame Interessenvertretung gegenüber Gemeinden, Mitgestaltung eines entstehenden Qualitätslabels – die Mitgliedschaft bietet echten Mehrwert für Ihren Alltag als Gastgeber:in.</p>
        <a href="/mitgliedschaft/" class="btn btn-accent">Mehr erfahren</a>
      </div>
      <Image src={sujet7} alt="" width={1024} height={959} />
    </div>
  </section>
</Layout>

<style>
  .grid-3 p {
    margin-inline: auto;
  }

  .grid-2 h2 { margin-bottom: var(--space-2); }
  .grid-2 p { margin-bottom: var(--space-3); }

  .paths {
    gap: var(--space-4);
    align-items: stretch;
  }

  .path-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-1);
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-subtle);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .path-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .path-card h2 {
    margin-top: var(--space-2);
    margin-bottom: var(--space-1);
  }

  .path-card p {
    margin-bottom: var(--space-3);
  }

  .path-card .btn {
    margin-top: auto;
  }

  @media (max-width: 700px) {
    .paths { grid-template-columns: 1fr; }
  }

  /* Position / Persona-B-Band */
  .eyebrow {
    margin-bottom: 0.35rem;
    color: var(--color-primary);
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
  }

  .position-band h2 { margin-bottom: var(--space-2); }
  .position-band p { margin-bottom: var(--space-3); max-width: 68ch; }

  .position-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .text-link-strong {
    font-weight: 600;
    color: var(--color-primary);
  }

  .trust-note {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    margin-top: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
    font-size: var(--text-sm);
    color: var(--color-text-muted, var(--color-text));
    max-width: 68ch;
  }

  .trust-note :global(svg) {
    flex-shrink: 0;
    margin-top: 0.15rem;
    color: var(--color-primary);
  }

  .trust-note a {
    font-weight: 600;
    white-space: nowrap;
  }

  /* Mitglieder-Stimme */
  .testimonial {
    max-width: 60ch;
    margin-inline: auto;
    text-align: center;
  }

  .testimonial blockquote {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    line-height: 1.4;
    color: var(--color-heading);
  }

  .testimonial figcaption {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .testimonial figcaption a {
    font-weight: 600;
  }
</style>
