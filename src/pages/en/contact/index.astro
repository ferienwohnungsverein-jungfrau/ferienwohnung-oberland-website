---
import Layout from '../../../layouts/Layout.astro';
import kontakt from '../../../data/kontakt.json';
import { Image } from 'astro:assets';
import sujet4 from '../../../assets/images/ferienwohnungsverein-jungfrau-sujet-4.jpg';
---

<Layout
  title="Contact - Ferienwohnungsverein Jungfrau"
  description="Press inquiries or general questions to the Ferienwohnungsverein Jungfrau – reachable by email or association phone."
  langAlt="/kontakt/"
>
  <!-- Hero -->
  <section class="section page-hero hero--intro">
    <div class="container">
      <h1>Contact</h1>
      <p>For press inquiries and general questions, we're reachable by email or phone.</p>
    </div>
  </section>

  <!-- Contact details -->
  <section class="section section--subtle">
    <div class="container grid-2">
      <div class="kontakt-col">
        <h2>Press Inquiries</h2>
        <a href={`mailto:${kontakt.presseEmail}`} class="btn btn-accent center-btn">Email</a>
        <h2>Association Phone</h2>
        <a href={`tel:${kontakt.vereinsTelefonLink}`} class="btn btn-accent center-btn">{kontakt.vereinsTelefon}</a>
      </div>
      <Image src={sujet4} alt="" width={1024} height={739} />
    </div>
  </section>
</Layout>

<style>
  .kontakt-col {
    text-align: center;
  }

  .kontakt-col h2 {
    margin-bottom: var(--space-2);
  }

  .kontakt-col h2 + .btn {
    margin-bottom: var(--space-4);
  }

  .center-btn {
    margin-inline: auto;
  }
</style>
