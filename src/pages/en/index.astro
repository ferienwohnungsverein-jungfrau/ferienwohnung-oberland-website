---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
import { Image, getImage } from 'astro:assets';
import sujet1 from '../../assets/images/ferienwohnungsverein-jungfrau-sujet-1.jpg';
import sujet2 from '../../assets/images/ferienwohnungsverein-jungfrau-sujet-2.jpg';
import sujet7 from '../../assets/images/ferienwohnungsverein-jungfrau-sujet-7.jpg';

const heroBg = await getImage({ src: sujet2, width: 1600, height: 640, format: 'webp' });
---

<Layout
  title="Ferienwohnungsverein Jungfrau - Bernese Oberland"
  description="We host, employ, and live in the Bernese Oberland – bundling our professional exchange and representing our interests to municipalities and the public."
  langAlt="/"
>
  <!-- Hero -->
  <section class="section hero--statement" style={`background-image: url(${heroBg.src})`}>
    <div class="container">
      <h1>Ferienwohnungsverein Jungfrau</h1>
      <p class="hero__subline">An association of holiday apartment hosts in the Bernese Oberland. We foster professional exchange among ourselves – and contribute constructively to the debate on fair rules for short-term rentals.</p>
    </div>
  </section>

  <!-- Two-path hub -->
  <section class="section section--white">
    <div class="container grid-2 paths">
      <a href="/en/membership/" class="path-card">
        <Icon name="hotel" size={56} class="role-icon" />
        <h2>I host</h2>
        <p>Professional exchange, practical know-how, and efforts towards a quality label – become part of an active community of holiday apartment hosts.</p>
        <span class="btn btn-accent">Membership</span>
      </a>
      <a href="/en/our-proposal/" class="path-card">
        <Icon name="puzzle-piece" size={56} class="role-icon" />
        <h2>I'm interested in the Airbnb debate</h2>
        <p>Municipal councillor, journalist, or simply interested in the regulation debate? We acknowledge the housing problem – and show a path that works.</p>
        <span class="btn btn-accent">Our Proposal</span>
      </a>
    </div>
  </section>

  <!-- Why we rent out -->
  <section class="section section--subtle">
    <div class="container grid-2">
      <Image src={sujet1} alt="" width={1024} height={768} />
      <div>
        <h2>Why we rent out</h2>
        <p>The reasons vary: some of us offer holiday apartments in our own home. Others rent out separate units. What we share: we do this with commitment – and with responsibility towards our guests and our region.</p>
        <a href="/en/about-us/" class="btn btn-accent">More about us</a>
      </div>
    </div>
  </section>

  <!-- Position / Persona B: keeps the debate path present while scrolling -->
  <section class="section section--white">
    <div class="container">
      <div class="position-band">
        <div>
          <p class="eyebrow">Our Position</p>
          <h2>At the Heart of the Debate on Fair Rules</h2>
          <p>Five Bödeli municipalities are deciding on the future of short-term rentals. We acknowledge the pressure on housing – and show, with the proven Wilderswil model, that protecting housing and a vibrant tourism sector can go hand in hand.</p>
          <div class="position-actions">
            <a href="/en/our-proposal/" class="btn btn-accent">Our Proposal</a>
            <a href="/en/for-municipalities-media/" class="text-link-strong">For Municipalities &amp; Media →</a>
          </div>
          <p class="trust-note"><Icon name="check-square" size={18} /><span>Fact-based and transparent: our statements rest on studies and official data. <a href="/en/sources/">Go to Sources →</a></span></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Member voice -->
  <section class="section section--subtle">
    <div class="container">
      <figure class="testimonial">
        <blockquote>
          “For over a year I've been a member of the Ferienwohnungsverein Jungfrau. The connections enrich me greatly. I'm glad that, as a member, I can actively help shape how the para-hotel sector is perceived.”
        </blockquote>
        <figcaption>Stefan Sterchi · <a href="https://surfershome.ch" target="_blank" rel="noopener">surfershome.ch</a></figcaption>
      </figure>
    </div>
  </section>

  <!-- Membership teaser -->
  <section class="section page-hero">
    <div class="container grid-2">
      <div>
        <h2>Become a member</h2>
        <p>Professional exchange with fellow hosts, joint representation towards municipalities, a say in a quality label taking shape – membership brings real value to your everyday work as a host.</p>
        <a href="/en/membership/" class="btn btn-accent">Learn more</a>
      </div>
      <Image src={sujet7} alt="" width={1024} height={959} />
    </div>
  </section>
</Layout>

<style>
  .grid-3 p {
    margin-inline: auto;
  }

  .grid-2 h2 { margin-bottom: var(--space-2); }
  .grid-2 p { margin-bottom: var(--space-3); }

  .paths {
    gap: var(--space-4);
    align-items: stretch;
  }

  .path-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-1);
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-subtle);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .path-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .path-card h2 {
    margin-top: var(--space-2);
    margin-bottom: var(--space-1);
  }

  .path-card p {
    margin-bottom: var(--space-3);
  }

  .path-card .btn {
    margin-top: auto;
  }

  @media (max-width: 700px) {
    .paths { grid-template-columns: 1fr; }
  }

  /* Position / Persona-B band */
  .eyebrow {
    margin-bottom: 0.35rem;
    color: var(--color-primary);
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
  }

  .position-band h2 { margin-bottom: var(--space-2); }
  .position-band p { margin-bottom: var(--space-3); max-width: 68ch; }

  .position-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .text-link-strong {
    font-weight: 600;
    color: var(--color-primary);
  }

  .trust-note {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    margin-top: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
    font-size: var(--text-sm);
    color: var(--color-text-muted, var(--color-text));
    max-width: 68ch;
  }

  .trust-note :global(svg) {
    flex-shrink: 0;
    margin-top: 0.15rem;
    color: var(--color-primary);
  }

  .trust-note a {
    font-weight: 600;
    white-space: nowrap;
  }

  /* Member voice */
  .testimonial {
    max-width: 60ch;
    margin-inline: auto;
    text-align: center;
  }

  .testimonial blockquote {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    line-height: 1.4;
    color: var(--color-heading);
  }

  .testimonial figcaption {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .testimonial figcaption a {
    font-weight: 600;
  }
</style>
