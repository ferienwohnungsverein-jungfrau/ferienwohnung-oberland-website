---
import Layout from '../../layouts/Layout.astro';
import kontakt from '../../data/kontakt.json';
import { Image } from 'astro:assets';
import sujet4 from '../../assets/images/ferienwohnungsverein-jungfrau-sujet-4.jpg';
---

<Layout
  title="Kontakt - Ferienwohnungsverein Jungfrau"
  description="Presseanfragen oder allgemeine Fragen an den Ferienwohnungsverein Jungfrau – per E-Mail oder Vereinstelefon erreichbar."
  langAlt="/en/contact/"
>
  <!-- Hero -->
  <section class="section page-hero hero--intro">
    <div class="container">
      <h1>Kontakt</h1>
      <p>Für Presseanfragen und allgemeine Fragen sind wir per E-Mail oder Telefon erreichbar.</p>
    </div>
  </section>

  <!-- Kontaktdaten -->
  <section class="section section--subtle">
    <div class="container grid-2">
      <div class="kontakt-col">
        <h2>Presseanfragen</h2>
        <p class="kontakt-person">Ansprechperson: <strong>Franz Hefti</strong>, Medien &amp; Kommunikation</p>
        <a href={`mailto:${kontakt.presseEmail}`} class="btn btn-accent center-btn">E-Mail</a>
        <h2>Vereinstelefon</h2>
        <a href={`tel:${kontakt.vereinsTelefonLink}`} class="btn btn-accent center-btn">{kontakt.vereinsTelefon}</a>
        <h2>Interesse anmelden</h2>
        <a href="/mitgliedschaft/#anmeldung" class="btn btn-accent center-btn">Zum Formular</a>
      </div>
      <Image src={sujet4} alt="" width={1024} height={739} />
    </div>
  </section>

  <!-- Weiterführende Links: löst die Sackgasse für Medien/Entscheider -->
  <section class="section section--white">
    <div class="container weiter">
      <h2>Mehr Hintergrund</h2>
      <div class="weiter-links">
        <a href="/unser-vorschlag/">Unser Vorschlag zur Kurzzeitvermietung →</a>
        <a href="/fuer-gemeinden-medien/">Für Gemeinden &amp; Medien →</a>
        <a href="/quellen/">Quellenverzeichnis →</a>
        <a href="/ueber-uns/">Wer wir sind →</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .kontakt-col {
    text-align: center;
  }

  .kontakt-col h2 {
    margin-bottom: var(--space-2);
  }

  .kontakt-col h2 + .btn {
    margin-bottom: var(--space-4);
  }

  .center-btn {
    margin-inline: auto;
  }

  .kontakt-person {
    margin-bottom: var(--space-2);
    font-size: var(--text-sm);
  }

  .weiter { text-align: center; }

  .weiter-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-3);
    align-items: center;
  }

  .weiter-links a {
    font-weight: 600;
  }
</style>
