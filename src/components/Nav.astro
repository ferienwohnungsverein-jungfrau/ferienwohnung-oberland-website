---
interface Props {
  locale?: 'de' | 'en';
  langAlt?: string;
}

const { locale = 'de', langAlt } = Astro.props;

const linksByLocale = {
  de: [
    { href: '/mitgliedschaft/', label: 'Für Vermietende' },
    { href: '/unser-vorschlag/', label: 'Unser Vorschlag' },
    { href: '/ueber-uns/', label: 'Über uns' },
    { href: '/fuer-gemeinden-medien/', label: 'Für Gemeinden & Medien' },
    { href: '/quellen/', label: 'Quellen' },
    { href: '/kontakt/', label: 'Kontakt' },
  ],
  en: [
    { href: '/en/membership/', label: 'For Hosts' },
    { href: '/en/our-proposal/', label: 'Our Proposal' },
    { href: '/en/about-us/', label: 'About Us' },
    { href: '/en/for-municipalities-media/', label: 'For Municipalities & Media' },
    { href: '/en/sources/', label: 'Sources' },
    { href: '/en/contact/', label: 'Contact' },
  ],
};

const links = linksByLocale[locale];
const currentPath = Astro.url.pathname;
function isActive(href: string) {
  return href === '/' || href === '/en/' ? currentPath === href : currentPath.startsWith(href);
}

const langSwitchHref = langAlt ?? (locale === 'en' ? '/' : '/en/');
const langSwitchLabel = locale === 'en' ? 'DE' : 'EN';
---

<header class="nav">
  <div class="container nav__inner">
    <a
      href={locale === 'en' ? '/en/' : '/'}
      class="nav__brand"
      aria-label={locale === 'en'
        ? 'Ferienwohnungsverein Jungfrau – to homepage'
        : 'Ferienwohnungsverein Jungfrau – zur Startseite'}
    >
      <span>Ferienwohnungsverein</span>
      <span>Jungfrau</span>
    </a>

    <nav class="nav__links" aria-label="Hauptnavigation">
      {links.map((link) => (
        <a href={link.href} class:list={['nav__link', { 'nav__link--active': isActive(link.href) }]}>
          {link.label}
        </a>
      ))}
      <a href={langSwitchHref} class="nav__lang" lang={locale === 'en' ? 'de' : 'en'}>{langSwitchLabel}</a>
    </nav>

    <button class="nav__toggle" aria-label="Menü öffnen" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div id="mobile-menu" class="nav__mobile" hidden>
    <nav aria-label="Mobile Navigation">
      {links.map((link) => (
        <a href={link.href} class:list={['nav__mobile-link', { 'nav__mobile-link--active': isActive(link.href) }]}>
          {link.label}
        </a>
      ))}
      <a href={langSwitchHref} class="nav__mobile-link" lang={locale === 'en' ? 'de' : 'en'}>{langSwitchLabel}</a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    height: 76px;
  }

  .nav__brand {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-white);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .nav__brand:hover {
    color: var(--color-white);
    text-shadow: 0 0 0.4px currentColor, 0 0 0.4px currentColor;
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .nav__link {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 400;
    white-space: nowrap;
    color: var(--color-text-on-dark);
    /* Reservierter, transparenter Unterstrich: verhindert Layout-Shift beim Hover/Aktiv */
    border-bottom: 2px solid transparent;
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }

  .nav__lang {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text-on-dark);
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: var(--radius-sm);
    padding: 0.2rem 0.55rem;
    transition: color 0.2s, border-color 0.2s;
  }

  .nav__lang:hover {
    color: var(--color-white);
    border-color: var(--color-white);
  }

  .nav__link--active {
    color: var(--color-white);
    border-bottom-color: var(--color-accent);
  }

  .nav__link:hover {
    color: var(--color-white);
    border-bottom-color: rgba(255, 255, 255, 0.6);
  }

  .nav__toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    min-width: 44px;
    min-height: 44px;
    padding: 0.5rem;
  }

  .nav__toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-white);
    border-radius: 2px;
  }

  .nav__mobile {
    padding: var(--space-2) var(--container-pad) var(--space-3);
    background: var(--color-primary-dark);
  }

  .nav__mobile nav {
    display: flex;
    flex-direction: column;
  }

  .nav__mobile-link {
    display: block;
    font-size: var(--text-base);
    color: var(--color-text-on-dark);
    padding: 0.6rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }

  .nav__mobile-link--active,
  .nav__mobile-link:hover {
    color: var(--color-white);
    font-weight: 600;
  }

  /* Hamburger greift, bevor die volle Nav (Wortmarke + lange Labels) überläuft –
     so ist das Menü bei jeder Breite und auf jeder Seite konsistent (DE wie EN). */
  @media (max-width: 1180px) {
    .nav__links { display: none; }
    .nav__toggle { display: flex; }
  }
</style>

<script>
  const toggle = document.querySelector('.nav__toggle') as HTMLButtonElement;
  const mobileMenu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.hidden === false;
    mobileMenu!.hidden = isOpen;
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
