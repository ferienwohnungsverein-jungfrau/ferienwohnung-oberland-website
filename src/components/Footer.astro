---
import DigyCredit from './DigyCredit.astro';

interface Props {
  locale?: 'de' | 'en';
}

const { locale = 'de' } = Astro.props;
const datenschutzHref = locale === 'en' ? '/en/privacy/' : '/datenschutz/';
const impressumHref = locale === 'en' ? '/en/imprint/' : '/impressum/';
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <p>© 2026 Ferienwohnungsverein Jungfrau</p>
      <DigyCredit domain="ferienwohnungsverein-jungfrau.ch" />
    </div>
    <p>
      {locale === 'en' ? (
        <><a href={impressumHref}>Imprint</a> · <a href={datenschutzHref}>Privacy Policy</a></>
      ) : (
        <><a href={impressumHref}>Impressum</a> · <a href={datenschutzHref}>Datenschutzerklärung</a></>
      )}
    </p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg-subtle);
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-3);
  }

  .footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    flex-wrap: wrap;
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  /* © und Credit gehören zusammen, sind aber zwei eigene Zeilen –
     der Credit ist die kleinere Zeile darunter (siehe DigyCredit.astro). */
  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 0.25em;
  }

  .footer__inner a {
    color: var(--color-primary);
  }

  /* Gleicher Faux-Bold-Hover wie in der Hauptnavigation (Nav.astro):
     text-shadow statt font-weight, damit sich Text nicht verschiebt. */
  .footer__inner a:hover {
    text-shadow: 0 0 0.4px currentColor, 0 0 0.4px currentColor;
  }

  @media (max-width: 700px) {
    .footer__inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
