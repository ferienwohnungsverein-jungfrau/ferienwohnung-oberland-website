---
interface Props {
  locale?: 'de' | 'en';
}

const { locale = 'de' } = Astro.props;
const datenschutzHref = locale === 'en' ? '/en/privacy/' : '/datenschutz/';
const quellenHref = locale === 'en' ? '/en/sources/' : '/quellen/';
const impressumHref = locale === 'en' ? '/en/imprint/' : '/impressum/';
---

<footer class="footer">
  <div class="container footer__inner">
    {locale === 'en' ? (
      <>
        <p>Website © 2026 <a href="mailto:office@surfershome.ch">DIGY.CH</a></p>
        <p><a href={quellenHref}>Sources</a> · <a href={impressumHref}>Imprint</a> · <a href={datenschutzHref}>Privacy Policy</a></p>
      </>
    ) : (
      <>
        <p>Website © 2026 <a href="mailto:office@surfershome.ch">DIGY.CH</a></p>
        <p><a href={quellenHref}>Quellen</a> · <a href={impressumHref}>Impressum</a> · <a href={datenschutzHref}>Datenschutzerklärung</a></p>
      </>
    )}
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg-subtle);
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-3);
  }

  .footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    flex-wrap: wrap;
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .footer__inner a {
    color: var(--color-primary);
  }

  /* Gleicher Faux-Bold-Hover wie in der Hauptnavigation (Nav.astro):
     text-shadow statt font-weight, damit sich Text nicht verschiebt. */
  .footer__inner a:hover {
    text-shadow: 0 0 0.4px currentColor, 0 0 0.4px currentColor;
  }

  @media (max-width: 700px) {
    .footer__inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
