---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import kontakt from '../data/kontakt.json';

interface Props {
  title: string;
  description?: string;
  /** Pfad derselben Seite in der jeweils anderen Sprache, z.B. "/en/about-us/" bzw. "/ueber-uns/" */
  langAlt?: string;
}

const {
  title,
  description = 'Wir sind Gastgeber:innen, Arbeitgeber:innen und Nachbarn – als Ferienwohnungsbetreibende im Berner Oberland setzen wir uns für faire Regeln und lebendige Gemeinden ein.',
  langAlt,
} = Astro.props;

const locale = Astro.currentLocale === 'en' ? 'en' : 'de';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Ferienwohnungsverein Jungfrau',
  alternateName: ['IGFI – Ferienwohnungsbetreibende Berner Oberland', 'Verein für Immobilieneigentümer und Ferienwohnungsbetreiber Interlaken und Umgebung'],
  url: 'https://ferienwohnungsverein-jungfrau.ch',
  areaServed: {
    '@type': 'Place',
    name: 'Interlaken und Umgebung, Berner Oberland',
  },
  contactPoint: [
    {
      '@type': 'ContactPoint',
      telephone: kontakt.vereinsTelefonLink,
      contactType: 'customer service',
      areaServed: 'CH',
      availableLanguage: ['German', 'English'],
    },
    {
      '@type': 'ContactPoint',
      email: kontakt.presseEmail,
      contactType: 'media relations',
      areaServed: 'CH',
      availableLanguage: ['German', 'English'],
    },
  ],
};
---

<!doctype html>
<html lang={locale === 'en' ? 'en' : 'de-CH'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang={locale === 'en' ? 'en' : 'de'} href={canonicalURL} />
    {langAlt && <link rel="alternate" hreflang={locale === 'en' ? 'de' : 'en'} href={new URL(langAlt, Astro.site)} />}
    {langAlt && <link rel="alternate" hreflang="x-default" href={new URL(locale === 'en' ? langAlt : Astro.url.pathname, Astro.site)} />}

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={locale === 'en' ? 'en_US' : 'de_DE'} />
    <meta property="og:site_name" content="Ferienwohnungsbetreibende Berner Oberland" />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

    <slot name="head" />
  </head>

  <body>
    <Nav locale={locale} langAlt={langAlt} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
